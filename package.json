{
  "name": "gorola-app",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "ci:quality": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "ci:prisma": "pnpm --filter @gorola/api exec prisma generate && pnpm --filter @gorola/api exec prisma migrate deploy"
  },
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/dotenv-safe": "^9.1.0",
    "@types/node": "^22.14.1",
    "@typescript-eslint/eslint-plugin": "^8.30.1",
    "@typescript-eslint/parser": "^8.30.1",
    "eslint": "^9.24.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^16.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
